<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradient fill -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="@color/glass_gradient_top"
                android:endColor="@color/glass_gradient_bottom" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Frosted tint -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_input_bg" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Outer border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/glass_border" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Inner highlight -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/glass_border_subtle" />
            <corners android:radius="27dp" />
        </shape>
    </item>
</layer-list>
