<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF0D0D1A" />
        </shape>
    </item>
    <!-- Top-left purple orb -->
    <item
        android:top="-120dp"
        android:left="-120dp"
        android:right="200dp"
        android:bottom="300dp">
        <shape android:shape="oval">
            <solid android:color="#556C3483" />
        </shape>
    </item>
    <!-- Center-right blue orb -->
    <item
        android:top="100dp"
        android:left="150dp"
        android:right="-100dp"
        android:bottom="100dp">
        <shape android:shape="oval">
            <solid android:color="#441E66F5" />
        </shape>
    </item>
    <!-- Bottom-left teal orb -->
    <item
        android:top="350dp"
        android:left="-80dp"
        android:right="250dp"
        android:bottom="-80dp">
        <shape android:shape="oval">
            <solid android:color="#3340A02B" />
        </shape>
    </item>
</layer-list>
