<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Warm white base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFF0F4FF" />
        </shape>
    </item>
    <!-- Top-left lavender orb -->
    <item
        android:top="-100dp"
        android:left="-100dp"
        android:right="180dp"
        android:bottom="320dp">
        <shape android:shape="oval">
            <solid android:color="#448839EF" />
        </shape>
    </item>
    <!-- Center-right blue orb -->
    <item
        android:top="80dp"
        android:left="160dp"
        android:right="-80dp"
        android:bottom="120dp">
        <shape android:shape="oval">
            <solid android:color="#331E66F5" />
        </shape>
    </item>
    <!-- Bottom-left green orb -->
    <item
        android:top="360dp"
        android:left="-60dp"
        android:right="260dp"
        android:bottom="-60dp">
        <shape android:shape="oval">
            <solid android:color="#2240A02B" />
        </shape>
    </item>
</layer-list>
