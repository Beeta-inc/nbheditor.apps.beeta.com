<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle gradient fill -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/glass_gradient_top"
                android:endColor="@color/glass_gradient_bottom" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Frosted tint layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_tint" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Outer border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/glass_border" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Inner highlight (top edge) -->
    <item android:top="0dp" android:bottom="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/glass_border_subtle" />
            <corners android:radius="17dp" />
        </shape>
    </item>
</layer-list>
