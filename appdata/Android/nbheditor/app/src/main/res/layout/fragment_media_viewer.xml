<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/viewerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:fitsSystemWindows="false">

    <!-- Header — top padding applied in code to clear status bar -->
    <LinearLayout
        android:id="@+id/viewerHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:background="#DD000000"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnViewerClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvViewerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:maxLines="1"
            android:ellipsize="middle"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <ImageButton
            android:id="@+id/btnViewerDownload"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/stat_sys_download"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Download" />
    </LinearLayout>

    <!-- IMAGE viewer -->
    <com.beeta.nbheditor.ZoomableImageView
        android:id="@+id/imageViewer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#FF000000"
        android:contentDescription="Image"
        app:layout_constraintTop_toBottomOf="@id/viewerHeader"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Unused stub kept for ID compatibility -->
    <View
        android:id="@+id/imageViewerFallback"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/viewerHeader"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- VIDEO viewer -->
    <TextureView
        android:id="@+id/videoViewer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/viewerHeader"
        app:layout_constraintBottom_toTopOf="@id/videoControls" />

    <!-- Video controls bar -->
    <LinearLayout
        android:id="@+id/videoControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#DD000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <SeekBar
            android:id="@+id/videoSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="@color/accent_primary"
            android:thumbTint="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <ImageButton
                android:id="@+id/btnVideoRewind"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_media_rew"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Rewind 10s" />

            <ImageButton
                android:id="@+id/btnVideoPlayPause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@android:drawable/ic_media_play"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:contentDescription="Play/Pause" />

            <ImageButton
                android:id="@+id/btnVideoForward"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_media_ff"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Forward 10s" />

            <TextView
                android:id="@+id/tvVideoTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00 / 0:00"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:gravity="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- AUDIO viewer -->
    <LinearLayout
        android:id="@+id/audioViewer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/viewerHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Music note icon -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="60dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/accent_primary"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="&#127911;"
                android:textSize="56sp"
                android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvAudioName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="32dp" />

        <SeekBar
            android:id="@+id/audioSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="@color/accent_primary"
            android:thumbTint="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvAudioTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvAudioDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnAudioRewind"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@android:drawable/ic_media_rew"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Rewind 10s" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnAudioPlayPause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_media_play"
                app:backgroundTint="@color/accent_primary"
                app:tint="@color/white"
                app:fabSize="normal"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:contentDescription="Play/Pause" />

            <ImageButton
                android:id="@+id/btnAudioForward"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@android:drawable/ic_media_ff"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Forward 10s" />
        </LinearLayout>
    </LinearLayout>

    <!-- DOCUMENT / PDF viewer -->
    <WebView
        android:id="@+id/documentViewer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#FFFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/viewerHeader"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/viewerProgress"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="@color/accent_primary"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Error -->
    <TextView
        android:id="@+id/tvViewerError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#AAFFFFFF"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
