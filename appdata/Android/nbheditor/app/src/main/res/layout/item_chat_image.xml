<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="56dp"
    android:paddingTop="3dp"
    android:paddingBottom="6dp"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✦ Beeta AI · Image"
        android:textSize="10sp"
        android:textColor="@color/accent_primary"
        android:paddingStart="2dp"
        android:paddingBottom="3dp"
        android:letterSpacing="0.05" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#26FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/divider">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/generatedImage"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:scaleType="centerCrop"
                android:contentDescription="Generated image" />

            <TextView
                android:id="@+id/imagePromptLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/editor_hint"
                android:paddingTop="6dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/insertImageBtn"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="4dp"
        android:text="Insert into Editor"
        android:textSize="11sp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp"
        android:textColor="@color/editor_line_number_text" />

</LinearLayout>
