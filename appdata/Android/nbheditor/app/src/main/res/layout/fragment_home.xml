<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editor_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Glass Header -->
        <LinearLayout
            android:id="@+id/homeHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="28dp"
            android:paddingBottom="16dp"
            android:background="@color/editor_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/homeTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✦ NBH Editor"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/editor_text"
                        android:letterSpacing="0.01" />

                    <TextView
                        android:id="@+id/fileCountLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="by Beeta Technologies"
                        android:textSize="12sp"
                        android:textColor="@color/accent_primary"
                        android:paddingTop="2dp" />
                </LinearLayout>

                <!-- Glass toggle button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGlassToggle"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Glass"
                    android:textSize="11sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="8dp"
                    app:strokeColor="@color/accent_primary"
                    app:strokeWidth="1dp"
                    android:textColor="@color/accent_primary" />

                <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                    android:id="@+id/btnNewFile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_new_file"
                    app:backgroundTint="@color/accent_primary"
                    android:textColor="@color/editor_bg"
                    app:iconTint="@color/editor_bg"
                    app:elevation="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Search bar -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/searchCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            app:cardBackgroundColor="@color/editor_surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="14sp"
                    android:paddingEnd="8dp" />

                <EditText
                    android:id="@+id/searchBar"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Search files..."
                    android:textColorHint="@color/editor_hint"
                    android:textColor="@color/editor_text"
                    android:textSize="13sp"
                    android:background="@null"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sort / Open row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/sortLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Recent files"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/editor_line_number_text" />

            <TextView
                android:id="@+id/btnOpenFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open file..."
                android:textSize="12sp"
                android:textColor="@color/accent_primary"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/emptyHomeState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦"
                android:textSize="56sp"
                android:textColor="@color/accent_primary"
                android:alpha="0.4" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No files yet"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/editor_text"
                android:paddingTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap New to create your first file"
                android:textSize="13sp"
                android:textColor="@color/editor_hint"
                android:paddingTop="8dp" />

        </LinearLayout>

        <!-- File grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/fileGrid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:visibility="gone" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
