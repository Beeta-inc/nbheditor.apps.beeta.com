<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="56dp"
    android:paddingTop="3dp"
    android:paddingBottom="6dp"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Beeta AI"
        android:textSize="10sp"
        android:textColor="@color/accent_primary"
        android:paddingStart="2dp"
        android:paddingBottom="3dp"
        android:letterSpacing="0.05" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/chat_ai_bubble"
        app:cardCornerRadius="4dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/divider">

        <TextView
            android:id="@+id/messageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textColor="@color/chat_ai_text"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:maxWidth="300dp"
            android:fontFamily="sans-serif" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Insert into editor button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/insertBtn"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="4dp"
        android:text="Insert into Editor"
        android:textSize="11sp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        app:icon="@drawable/ic_insert_editor"
        app:iconSize="14dp"
        app:iconTint="@color/accent_secondary"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp"
        android:textColor="@color/editor_line_number_text" />

</LinearLayout>
