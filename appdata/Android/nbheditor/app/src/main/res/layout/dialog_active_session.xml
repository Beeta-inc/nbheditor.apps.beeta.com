<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Active Session"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary" />

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@android:drawable/presence_online"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvSessionCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="neAB12X"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@android:color/darker_gray"
            android:padding="8dp"
            android:textColor="@android:color/white" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewUsers"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Users"
            android:textAllCaps="false"
            app:strokeColor="?attr/colorPrimary"
            app:strokeWidth="1dp"
            app:icon="@android:drawable/ic_menu_myplaces"
            app:iconGravity="start"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeaveSession"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Leave"
            android:textAllCaps="false"
            app:icon="@android:drawable/ic_menu_close_clear_cancel"
            app:iconGravity="start"
            android:backgroundTint="?attr/colorError"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 Tip: Share the session code with others to collaborate in real-time"
        android:textSize="12sp"
        android:textColor="?android:attr/textColorSecondary"
        android:padding="12dp"
        android:background="?attr/colorSurfaceVariant"
        android:drawablePadding="8dp" />

</LinearLayout>
