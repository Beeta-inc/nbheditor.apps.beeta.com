<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/transparent">

    <!-- Header with animated pulse -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#E3F2FD">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp">

            <ImageView
                android:id="@+id/ivSessionPulse"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/presence_online"
                android:layout_marginEnd="14dp"
                android:tint="#1976D2" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔗 Live Session"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Real-time collaboration active"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvSessionCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NE1ASOU"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:padding="14dp"
                android:background="#1976D2"
                android:textColor="@android:color/white"
                android:letterSpacing="0.15" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <!-- First row: Users and Leave -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewUsers"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="View Users"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconGravity="textStart"
                app:iconSize="22dp"
                app:strokeColor="#1976D2"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeaveSession"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Leave"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#D32F2F"
                app:icon="@android:drawable/ic_menu_close_clear_cancel"
                app:iconGravity="textStart"
                app:iconSize="22dp"
                app:cornerRadius="14dp" />

        </LinearLayout>

        <!-- Second row: Chat and Video Call -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenChat"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="Chat"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#1976D2"
                app:icon="@android:drawable/ic_menu_send"
                app:iconGravity="textStart"
                app:iconSize="22dp"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVideoCall"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Video Call"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#4CAF50"
                app:icon="@android:drawable/presence_video_online"
                app:iconGravity="textStart"
                app:iconSize="22dp"
                app:cornerRadius="14dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Info card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="18dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡"
                android:textSize="28sp"
                android:layout_marginEnd="14dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Share the session code with others to collaborate. All changes sync instantly!"
                android:textSize="14sp"
                android:textColor="#616161"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
