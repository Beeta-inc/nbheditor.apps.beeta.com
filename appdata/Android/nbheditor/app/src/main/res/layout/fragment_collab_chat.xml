<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editor_bg">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/chatHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_glass_bar"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnCloseChat"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Back" />

        <!-- Avatar circle with improved styling -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/accent_primary"
            android:layout_marginEnd="12dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="💬"
                android:textSize="20sp"
                android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Team Chat"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/tvChatStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● online"
                android:textSize="12sp"
                android:textColor="#CCFFFFFF"
                android:drawablePadding="4dp" />
        </LinearLayout>

        <!-- Enhanced attachment buttons in header -->
        <ImageButton
            android:id="@+id/btnAttachImage"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Image"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnAttachDocument"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Document"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnAttachVoice"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Voice"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnAttachVideo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Video"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnVideoCall"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/presence_video_online"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Video Call" />
    </LinearLayout>

    <!-- @ mention popup (shown above input when user types @) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/mentionPopup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone"
        android:elevation="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/editor_surface"
        app:layout_constraintBottom_toTopOf="@id/inputBar">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMentionSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp"
            android:nestedScrollingEnabled="false" />
    </androidx.cardview.widget.CardView>

    <!-- Enhanced Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clipToPadding="false"
        android:background="@color/editor_bg"
        android:scrollbars="vertical"
        android:fadeScrollbars="true"
        android:scrollbarStyle="outsideOverlay"
        app:layout_constraintTop_toBottomOf="@id/chatHeader"
        app:layout_constraintBottom_toTopOf="@id/typingIndicatorBar" />

    <!-- Typing Indicator -->
    <LinearLayout
        android:id="@+id/typingIndicatorBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@color/editor_bg"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/replyPreviewLayout">

        <TextView
            android:id="@+id/tvTypingDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●●●"
            android:textSize="10sp"
            android:textColor="@color/accent_primary"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvTypingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Someone is typing..."
            android:textSize="12sp"
            android:textColor="@color/editor_hint"
            android:fontFamily="sans-serif-light" />
    </LinearLayout>

    <!-- Reply Preview -->
    <LinearLayout
        android:id="@+id/replyPreviewLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/editor_surface"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        android:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@id/inputBar">

        <View
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="@color/accent_primary"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/replyPreviewSender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/accent_primary" />

            <TextView
                android:id="@+id/replyPreviewText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Message preview..."
                android:textSize="13sp"
                android:textColor="@color/editor_hint"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnCancelReply"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/editor_hint"
            android:contentDescription="Cancel reply" />
    </LinearLayout>

    <!-- Enhanced Input Bar -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_glass_panel"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="bottom"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- To: chip -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/targetSelectorBar"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:layout_gravity="center_vertical"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/accent_primary"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <TextView
                    android:id="@+id/tvTargetDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@all"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:maxWidth="80dp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ▾"
                    android:textSize="10sp"
                    android:textColor="#CCFFFFFF" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Enhanced text input -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/input_bg"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider">

            <EditText
                android:id="@+id/etChatMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Type a message..."
                android:background="@null"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:maxLines="6"
                android:textSize="16sp"
                android:textColor="@color/editor_text"
                android:textColorHint="@color/editor_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:scrollbars="vertical" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Task button -->
        <ImageButton
            android:id="@+id/btnCreateTaskFromChat"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:src="@android:drawable/ic_menu_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/accent_secondary"
            android:contentDescription="Create task" />

        <!-- Send FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSendMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_send"
            app:backgroundTint="@color/accent_primary"
            app:tint="@color/white"
            app:fabSize="mini"
            app:elevation="2dp"
            android:contentDescription="Send" />
    </LinearLayout>

    <!-- Hidden views kept for binding compatibility -->
    <View android:id="@+id/headerDivider" android:layout_width="0dp" android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/chatHeader" />
    <View android:id="@+id/inputDivider" android:layout_width="0dp" android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/inputBar" />
    <LinearLayout android:id="@+id/quickActionsBar" android:layout_width="0dp"
        android:layout_height="0dp" android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/inputBar" />

</androidx.constraintlayout.widget.ConstraintLayout>
