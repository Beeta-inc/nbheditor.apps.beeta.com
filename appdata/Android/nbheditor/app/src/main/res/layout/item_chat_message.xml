<?xml version="1.0" encoding="utf-8"?>
<!-- Root is full-width so gravity on messageContainer works correctly -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!-- Bubble -->
    <LinearLayout
        android:id="@+id/messageContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/editor_surface"
        android:padding="10dp"
        android:elevation="1dp"
        android:layout_gravity="start"
        android:maxWidth="280dp">

        <!-- Sender name (hidden for own messages) -->
        <TextView
            android:id="@+id/tvSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/accent_primary"
            android:paddingBottom="2dp" />

        <!-- Text body -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Message content"
            android:textSize="15sp"
            android:textColor="@color/editor_text"
            android:lineSpacingMultiplier="1.3" />

        <!-- Image preview -->
        <ImageView
            android:id="@+id/ivMediaPreview"
            android:layout_width="240dp"
            android:layout_height="160dp"
            android:layout_marginTop="6dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:background="#11000000"
            android:contentDescription="Media" />

        <!-- Non-image attachment row -->
        <LinearLayout
            android:id="@+id/attachmentCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A4C6EF5"
            android:padding="8dp"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvAttachmentIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📄"
                android:textSize="22sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvAttachmentName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="filename.pdf"
                android:textSize="13sp"
                android:textColor="@color/accent_primary"
                android:maxLines="2"
                android:ellipsize="middle" />
        </LinearLayout>

        <!-- Open / Save row -->
        <LinearLayout
            android:id="@+id/mediaActionBar"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnOpenMedia"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="▶ Open"
                android:textSize="12sp"
                android:textColor="@color/accent_primary"
                android:textStyle="bold"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <View android:layout_width="1dp" android:layout_height="match_parent"
                android:background="@color/divider" />

            <TextView
                android:id="@+id/btnDownloadMedia"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="⬇ Save"
                android:textSize="12sp"
                android:textColor="@color/accent_secondary"
                android:textStyle="bold"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Timestamp + status row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="end"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvImportantBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ "
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvLinkedTaskBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ "
                android:textSize="11sp"
                android:textColor="@color/accent_secondary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:34"
                android:textSize="11sp"
                android:textColor="@color/editor_hint" />

            <!-- Read tick (shown only for own messages) -->
            <TextView
                android:id="@+id/tvReadTick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ✓"
                android:textSize="11sp"
                android:textColor="@color/accent_secondary"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Long-press action bar (shown below bubble) -->
    <LinearLayout
        android:id="@+id/messageActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/editor_surface"
        android:elevation="4dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/btnMarkImportant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐"
            android:textSize="18sp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnCreateTask"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textSize="18sp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnSetReminder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰"
            android:textSize="18sp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
