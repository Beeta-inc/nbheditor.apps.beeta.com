<?xml version="1.0" encoding="utf-8"?>
<!-- INCOMING: avatar on left, bubble on left, name above bubble -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="64dp"
    android:paddingTop="3dp"
    android:paddingBottom="3dp">

    <!-- Sender name above bubble -->
    <TextView
        android:id="@+id/tvSenderName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingBottom="2dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom">

        <!-- Avatar circle -->
        <FrameLayout
            android:id="@+id/avatarCard"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="6dp"
            android:layout_marginBottom="2dp">

            <View
                android:id="@+id/avatarBg"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_avatar_circle" />

            <TextView
                android:id="@+id/tvAvatarInitial"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Avatar" />
        </FrameLayout>

        <!-- Bubble -->
        <LinearLayout
            android:id="@+id/messageContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bubble_in"
            android:padding="10dp"
            android:maxWidth="240dp">

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:lineSpacingMultiplier="1.3" />

            <ImageView
                android:id="@+id/ivMediaPreview"
                android:layout_width="200dp"
                android:layout_height="140dp"
                android:layout_marginTop="6dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Media" />

            <LinearLayout
                android:id="@+id/attachmentCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A4C6EF5"
                android:padding="8dp"
                android:layout_marginTop="6dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvAttachmentIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvAttachmentName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="@color/accent_primary"
                    android:maxLines="2"
                    android:ellipsize="middle" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mediaActionBar"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btnOpenMedia"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Open"
                    android:textSize="12sp"
                    android:textColor="@color/accent_primary"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />

                <View android:layout_width="1dp" android:layout_height="match_parent"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/btnDownloadMedia"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Save"
                    android:textSize="12sp"
                    android:textColor="@color/accent_secondary"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="end"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvImportantBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvLinkedTaskBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/accent_secondary"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/editor_hint" />

                <TextView
                    android:id="@+id/tvReadTick"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" &#10003;"
                    android:textSize="11sp"
                    android:textColor="@color/accent_secondary"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/messageActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/editor_surface"
        android:elevation="4dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        android:layout_marginTop="2dp"
        android:layout_marginStart="40dp">

        <TextView android:id="@+id/btnMarkImportant"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#11088;" android:textSize="18sp" android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btnCreateTask"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#10003;" android:textSize="18sp" android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btnSetReminder"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#9200;" android:textSize="18sp" android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

</LinearLayout>
