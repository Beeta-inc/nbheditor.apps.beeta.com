<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/messageContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:elevation="2dp"
        android:layout_gravity="start"
        android:maxWidth="300dp">

        <!-- Sender + badges row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvSenderName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="User Name"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />

            <TextView
                android:id="@+id/tvImportantBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginStart="4dp" />

            <TextView
                android:id="@+id/tvLinkedTaskBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:visibility="gone"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Text message -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Message content"
            android:textSize="14sp"
            android:textColor="#212121"
            android:layout_marginTop="4dp" />

        <!-- Image preview (shown for image attachments) -->
        <ImageView
            android:id="@+id/ivMediaPreview"
            android:layout_width="240dp"
            android:layout_height="160dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:background="#11000000"
            android:contentDescription="Media preview" />

        <!-- Non-image attachment card (document / audio / video) -->
        <LinearLayout
            android:id="@+id/attachmentCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1976D2"
            android:padding="10dp"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvAttachmentIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📄"
                android:textSize="24sp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvAttachmentName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="filename.pdf"
                android:textSize="13sp"
                android:textColor="#1976D2"
                android:maxLines="2"
                android:ellipsize="middle" />
        </LinearLayout>

        <!-- Open / Download buttons (shown when attachment present) -->
        <LinearLayout
            android:id="@+id/mediaActionBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnOpenMedia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶ Open"
                android:textSize="12sp"
                android:textColor="#1976D2"
                android:textStyle="bold"
                android:padding="6dp"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#22000000" />

            <TextView
                android:id="@+id/btnDownloadMedia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⬇ Save"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:padding="6dp"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:34 PM"
            android:textSize="10sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp"
            android:layout_gravity="end" />
    </LinearLayout>

    <!-- Long-press actions -->
    <LinearLayout
        android:id="@+id/messageActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/btnMarkImportant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ Mark"
            android:textSize="11sp"
            android:textColor="#FF9800"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnCreateTask"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Task"
            android:textSize="11sp"
            android:textColor="#4CAF50"
            android:padding="4dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnSetReminder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰ Remind"
            android:textSize="11sp"
            android:textColor="#2196F3"
            android:padding="4dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
