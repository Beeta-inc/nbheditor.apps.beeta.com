<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/contentPane"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editor_bg">

    <LinearLayout
        android:id="@+id/editor_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/aiSuggestionContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Glass line numbers panel -->
        <ScrollView
            android:id="@+id/lineNumbersScroll"
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:background="@color/editor_line_numbers_bg">
            <LinearLayout
                android:id="@+id/lineNumbersVBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp"
                android:paddingEnd="8dp"
                android:paddingStart="4dp" />
        </ScrollView>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider" />

        <!-- Editor text area -->
        <EditText
            android:id="@+id/textArea"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/editor_bg"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:padding="10dp"
            android:fontFamily="monospace"
            android:textSize="15sp"
            android:textColor="@color/editor_text"
            android:textStyle="bold"
            android:textCursorDrawable="@null"
            android:lineSpacingMultiplier="1.5"
            android:hint="Start typing..."
            android:textColorHint="@color/editor_hint"
            android:scrollbars="vertical" />
    </LinearLayout>

    <!-- Glass AI suggestion chips bar -->
    <HorizontalScrollView
        android:id="@+id/aiSuggestionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@drawable/bg_glass_bar"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toBottomOf="@+id/editor_container"
        app:layout_constraintBottom_toTopOf="@+id/autoSaveContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:id="@+id/aiSuggestionList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦"
                android:textColor="@color/accent_primary"
                android:textSize="12sp"
                android:paddingEnd="6dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/autoSaveContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone"
        android:background="@drawable/bg_glass_bar"
        app:layout_constraintTop_toBottomOf="@+id/aiSuggestionContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/autoSaveLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saving..."
            android:textSize="11sp"
            android:textColor="@color/editor_line_number_text" />

        <ProgressBar
            android:id="@+id/autoSaveProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginStart="10dp"
            android:layout_gravity="center_vertical"
            android:progressTint="@color/accent_primary"
            android:progressBackgroundTint="@color/divider" />
    </LinearLayout>

    <!-- Glass overlay for AI processing -->
    <FrameLayout
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#99000000"
        android:elevation="10dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/overlayCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardBackgroundColor="#33FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#44FFFFFF">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center">

                <ProgressBar
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:indeterminateTint="@color/accent_primary" />

                <TextView
                    android:id="@+id/overlayText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/editor_text"
                    android:textSize="14sp"
                    android:text="Processing..." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
