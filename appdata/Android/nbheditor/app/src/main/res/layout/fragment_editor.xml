<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/contentPane"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Editor quick-key toolbar -->
    <HorizontalScrollView
        android:id="@+id/editorToolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/editor_surface"
        android:scrollbars="none"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/undoButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent_primary"
                android:contentDescription="Undo" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@color/divider"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/editorVoiceButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_mic"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent_primary"
                android:contentDescription="Voice to text" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@color/divider"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/insertImageButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_image"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent_secondary"
                android:contentDescription="Insert image" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@color/divider"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/textTypeButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent_primary"
                android:contentDescription="Text type" />

        </LinearLayout>
    </HorizontalScrollView>

    <View
        android:id="@+id/editorToolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/editorToolbar" />

    <!-- Document Tabs -->
    <HorizontalScrollView
        android:id="@+id/tabsScrollView"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/editor_surface"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/editorToolbarDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/tabsContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />
    </HorizontalScrollView>

    <View
        android:id="@+id/tabsDivider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/tabsScrollView" />

    <LinearLayout
        android:id="@+id/editor_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tabsDivider"
        app:layout_constraintBottom_toTopOf="@id/statusBarDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/lineNumbersScroll"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:background="@color/editor_line_numbers_bg">
            <LinearLayout
                android:id="@+id/lineNumbersVBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingEnd="10dp"
                android:paddingStart="6dp" />
        </ScrollView>

        <View
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:background="@color/divider" />

        <com.beeta.nbheditor.RichEditText
            android:id="@+id/textArea"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/editor_bg"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:padding="16dp"
            android:fontFamily="monospace"
            android:textSize="16sp"
            android:textColor="@color/editor_text"
            android:textCursorDrawable="@drawable/cursor_drawable"
            android:lineSpacingMultiplier="1.6"
            android:hint="Start typing..."
            android:textColorHint="@color/editor_hint"
            android:scrollbars="vertical" />
    </LinearLayout>

    <!-- Status Bar at Bottom -->
    <View
        android:id="@+id/statusBarDivider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider"
        app:layout_constraintBottom_toTopOf="@id/statusBar" />

    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:background="@color/editor_surface"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/statusWordCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Words: 0"
            android:textSize="11sp"
            android:textColor="@color/editor_line_number_text"
            android:paddingEnd="12dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="@color/divider"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/statusLineInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ln 1, Col 1"
            android:textSize="11sp"
            android:textColor="@color/editor_line_number_text"
            android:paddingEnd="12dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="@color/divider"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/statusFileType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Plain Text"
            android:textSize="11sp"
            android:textColor="@color/editor_line_number_text" />

        <TextView
            android:id="@+id/statusEncoding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UTF-8"
            android:textSize="11sp"
            android:textColor="@color/editor_line_number_text" />
    </LinearLayout>

    <!-- Voice Status Indicator for Editor - Overlay at bottom -->
    <LinearLayout
        android:id="@+id/editorVoiceStatusIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:background="@drawable/bg_glass_card"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="36dp"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/editorVoiceStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Voice mode active - no speech detected"
            android:textSize="13sp"
            android:textColor="@color/editor_text" />

        <com.beeta.nbheditor.VoiceEqualizerView
            android:id="@+id/editorVoiceEqualizer"
            android:layout_width="60dp"
            android:layout_height="28dp"
            android:visibility="gone" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/aiSuggestionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@color/editor_surface"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@id/editorVoiceStatusIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:id="@+id/aiSuggestionList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦"
                android:textColor="@color/accent_primary"
                android:textSize="12sp"
                android:paddingEnd="6dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/autoSaveContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone"
        android:background="@color/editor_surface"
        android:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@id/aiSuggestionContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/autoSaveLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saving..."
            android:textSize="11sp"
            android:textColor="@color/editor_line_number_text" />

        <ProgressBar
            android:id="@+id/autoSaveProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginStart="10dp"
            android:layout_gravity="center_vertical"
            android:progressTint="@color/accent_primary"
            android:progressBackgroundTint="@color/divider" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#99000000"
        android:elevation="10dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/overlayCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardBackgroundColor="#CC1E1E2E"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#44FFFFFF">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center">

                <ProgressBar
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:indeterminateTint="@color/accent_primary" />

                <TextView
                    android:id="@+id/overlayText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:text="Processing..." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
