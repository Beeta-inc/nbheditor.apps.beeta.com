<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/editor_bg">

    <ImageView
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/logo_beeta"
        android:scaleType="fitCenter"
        android:contentDescription="Beeta Logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NBH Editor"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/editor_text"
        android:letterSpacing="0.05"
        android:layout_marginTop="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="by Beeta Technologies"
        android:textSize="13sp"
        android:textColor="@color/editor_line_number_text"
        android:layout_marginTop="6dp" />

</LinearLayout>
