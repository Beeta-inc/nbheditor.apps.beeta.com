<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/editor_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Numerator:"
        android:textSize="14sp"
        android:textColor="@color/editor_text"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/numerator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:padding="12dp"
        android:hint="e.g., x+1, a^2"
        android:textColorHint="@color/editor_hint"
        android:textColor="@color/editor_text"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Denominator:"
        android:textSize="14sp"
        android:textColor="@color/editor_text"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/denominator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:padding="12dp"
        android:hint="e.g., x-1, b^2"
        android:textColorHint="@color/editor_hint"
        android:textColor="@color/editor_text" />

</LinearLayout>
