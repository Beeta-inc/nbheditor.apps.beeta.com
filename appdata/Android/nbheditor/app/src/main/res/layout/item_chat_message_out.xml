<?xml version="1.0" encoding="utf-8"?>
<!-- OUTGOING: no avatar, bubble on right, "You" label on right -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="64dp"
    android:paddingEnd="8dp"
    android:paddingTop="3dp"
    android:paddingBottom="3dp">

    <!-- "You" label right-aligned -->
    <TextView
        android:id="@+id/tvSenderNameOut"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#25D366"
        android:gravity="end"
        android:paddingBottom="2dp" />

    <!-- Bubble right-aligned -->
    <LinearLayout
        android:id="@+id/messageContainerOut"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_out"
        android:padding="10dp"
        android:maxWidth="240dp">

        <TextView
            android:id="@+id/tvMessageOut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#1A1A1A"
            android:lineSpacingMultiplier="1.3" />

        <ImageView
            android:id="@+id/ivMediaPreviewOut"
            android:layout_width="200dp"
            android:layout_height="140dp"
            android:layout_marginTop="6dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="Media" />

        <LinearLayout
            android:id="@+id/attachmentCardOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A25D366"
            android:padding="8dp"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvAttachmentIconOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvAttachmentNameOut"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="#1A1A1A"
                android:maxLines="2"
                android:ellipsize="middle" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/mediaActionBarOut"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnOpenMediaOut"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Open"
                android:textSize="12sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <View android:layout_width="1dp" android:layout_height="match_parent"
                android:background="#33000000" />

            <TextView
                android:id="@+id/btnDownloadMediaOut"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Save"
                android:textSize="12sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="end"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvTimestampOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#555555" />

            <TextView
                android:id="@+id/tvReadTickOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" &#10003;"
                android:textSize="11sp"
                android:textColor="#25D366" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/messageActionsOut"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="end"
        android:background="@color/editor_surface"
        android:elevation="4dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        android:layout_marginTop="2dp">

        <TextView android:id="@+id/btnMarkImportantOut"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#11088;" android:textSize="18sp" android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btnCreateTaskOut"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#10003;" android:textSize="18sp" android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btnSetReminderOut"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#9200;" android:textSize="18sp" android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

</LinearLayout>
