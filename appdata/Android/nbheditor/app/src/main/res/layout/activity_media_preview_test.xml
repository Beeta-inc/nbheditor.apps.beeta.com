<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/editor_bg">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Media Preview Test"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/editor_text"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select media to test preview extraction:"
        android:textSize="14sp"
        android:textColor="@color/editor_text"
        android:layout_marginBottom="16dp" />

    <!-- Selection Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnSelectImage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📷 Image"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnSelectVideo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎥 Video"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnSelectDocument"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📄 Doc"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Preview Area -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/editor_surface">

            <ImageView
                android:id="@+id/previewImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:contentDescription="Preview" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="No preview yet\nSelect media above"
                android:textSize="16sp"
                android:textColor="@color/editor_hint"
                android:gravity="center"
                android:id="@+id/placeholderText" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Status Text -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/editor_surface">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready to test preview generation"
            android:textSize="14sp"
            android:textColor="@color/editor_text"
            android:padding="12dp"
            android:fontFamily="monospace" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Features:\n• Image preview with scaling\n• Video first frame extraction\n• PDF first page rendering\n• Document type icons\n• Automatic caching"
        android:textSize="12sp"
        android:textColor="@color/editor_hint"
        android:layout_marginTop="16dp"
        android:lineSpacingMultiplier="1.3" />

</LinearLayout>
