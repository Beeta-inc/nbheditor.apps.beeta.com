<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/videoChatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Remote video (full screen) -->
    <io.livekit.android.renderer.TextureViewRenderer
        android:id="@+id/remoteVideoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Local video (picture-in-picture) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/localVideoCard"
        android:layout_width="100dp"
        android:layout_height="140dp"
        android:layout_margin="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <io.livekit.android.renderer.TextureViewRenderer
            android:id="@+id/localVideoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.cardview.widget.CardView>

    <!-- Top info bar -->
    <LinearLayout
        android:id="@+id/topInfoBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/gradient_top_overlay"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="30dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvParticipants"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 participant"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tvCallDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="14sp"
                android:textColor="#CCFFFFFF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Connected"
            android:textSize="13sp"
            android:textColor="#4CAF50"
            android:background="#1A000000"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:drawablePadding="6dp" />
    </LinearLayout>

    <!-- Bottom control bar -->
    <LinearLayout
        android:id="@+id/controlsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_bottom_overlay"
        android:paddingTop="30dp"
        android:paddingBottom="40dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal">

            <!-- Microphone toggle -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnToggleMic"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="10dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#33FFFFFF">

                <ImageView
                    android:id="@+id/imgMic"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:tint="@color/white" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Video toggle -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnToggleVideo"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="10dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#33FFFFFF">

                <ImageView
                    android:id="@+id/imgVideo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/presence_video_online"
                    android:tint="@color/white" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Rotate camera -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnRotateCamera"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="10dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#33FFFFFF">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_rotate"
                    android:tint="@color/white" />
            </com.google.android.material.card.MaterialCardView>

            <!-- End call -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnEndCall"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_margin="10dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#F44336">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_call"
                    android:rotation="135"
                    android:tint="@color/white" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Leave (for non-host) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnLeaveCall"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="10dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#33FFFFFF">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_revert"
                    android:tint="@color/white" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
