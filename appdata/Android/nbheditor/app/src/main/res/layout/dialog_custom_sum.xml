<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/editor_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lower Limit:"
        android:textSize="14sp"
        android:textColor="@color/editor_text"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/sumLowerLimit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:padding="12dp"
        android:hint="e.g., i=1, k=0, n=1"
        android:textColorHint="@color/editor_hint"
        android:textColor="@color/editor_text"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upper Limit:"
        android:textSize="14sp"
        android:textColor="@color/editor_text"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/sumUpperLimit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:padding="12dp"
        android:hint="e.g., n, \\infty, 100"
        android:textColorHint="@color/editor_hint"
        android:textColor="@color/editor_text"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expression:"
        android:textSize="14sp"
        android:textColor="@color/editor_text"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/sumExpression"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:padding="12dp"
        android:hint="e.g., i^2, a_i, \\frac{1}{n}"
        android:textColorHint="@color/editor_hint"
        android:textColor="@color/editor_text" />

</LinearLayout>
