<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Normal dark theme - fully opaque -->
    <style name="Theme.Nbheditor" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/accent_purple</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorSecondaryVariant">@color/accent_secondary</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/toolbar_bg</item>
        <item name="android:navigationBarColor">@color/bottom_nav_bg</item>
        <item name="android:windowBackground">@color/editor_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="bottomNavigationStyle">@style/Widget.Nbheditor.BottomNav</item>
    </style>

    <style name="Theme.Nbheditor.NoActionBar" parent="Theme.Nbheditor">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Nbheditor.Splash" parent="Theme.Nbheditor.NoActionBar">
        <item name="android:windowBackground">@color/editor_bg</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="Theme.Nbheditor.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="android:background">@color/toolbar_bg</item>
    </style>

    <style name="Theme.Nbheditor.PopupOverlay" parent="ThemeOverlay.AppCompat.Dark" />

    <style name="Widget.Nbheditor.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bottom_nav_bg</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemRippleColor">@color/accent_primary</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.Nbheditor.NavView" parent="Widget.MaterialComponents.NavigationView">
        <item name="android:background">#00000000</item>
    </style>
</resources>
